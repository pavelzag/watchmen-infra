# Local .terraform directory
.terraform/

# State files
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Variables and secrets
*.tfvars
*.tfvars.json
.env
.env.*
!.env.example
!.env.*.example

# Generated Terraform artifacts
lambda_payload.zip

# Local CLI configuration
.terraformrc
terraform.rc

# Terraform plan files
*.tfplan

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Backup snapshots and generated lockfiles inside backups
backup/**/.terraform.lock.hcl
